# .env.perf — Variables pour le mode perf avec émulateur Pub/Sub GCP local
#
# Usage :
#   docker-compose --env-file .env.perf --profile perf up -d
#
# NE PAS committer de valeurs secrets dans ce fichier.
# SECRET_KEY doit toujours être injectée depuis l'environnement hôte.

# ── Pub/Sub Emulator ──────────────────────────────────────────────────────────
# Pointe vers le container pubsub_emulator (DNS Docker interne).
PUBSUB_EMULATOR_HOST=pubsub_emulator:8085
PUBSUB_CV_IMPORT_TOPIC=cv-import-topic
GCP_PROJECT_ID=test-project

# ── cv_api : contournement OIDC en local ─────────────────────────────────────
# En production, PUBSUB_CV_IMPORT_AUDIENCE est l'URL Cloud Run de cv_api.
# En local, on passe "local-test" pour que VerifyOIDC ne bloque pas.
# ⚠️  Ne jamais utiliser cette valeur en production.
PUBSUB_INVOKER_SA_EMAIL=mock@test.iam.gserviceaccount.com
PUBSUB_CV_IMPORT_AUDIENCE=local-test
MOCK_M2M_JWT=

# ── LLM Mock ─────────────────────────────────────────────────────────────────
# Redirige cv_api et les agents vers le mock Gemini local (port 8099).
GEMINI_API_BASE_URL=http://mock_gemini:8099
VERTEX_API_BASE_URL=http://mock_gemini:8099
GOOGLE_API_KEY=mock-key-local
