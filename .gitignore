# =========================
# Terraform Gitignore
# =========================

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json
*.auto.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# =========================
# Frontend & Build
# =========================
node_modules/
dist/
dist-ssr/
*.local

# =========================
# Tests
# =========================
pytest.log
*_test.db
patch*.py
test_*.py.antigravity_env
.venv_test/
*/\.venv_test/

# =========================
# Temp / Scratch
# =========================
.tmp/
scratch_*.py
reports/
