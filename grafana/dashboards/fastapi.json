    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "title": "Average Response Time (ms)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum[1m])) by (service) / sum(rate(http_request_duration_seconds_count[1m])) by (service) * 1000",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "title": "Error Rate (non-2xx)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{status!~\"2..\"}[1m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    }
